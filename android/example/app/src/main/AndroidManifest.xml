<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for the SDK's network calls. Flutter's DEBUG AAR injects this
         automatically, but the RELEASE AAR does not — without it a release
         build has no network and the feed fails with
         domain_tracker_server_not_found. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".ExampleApp"
        android:label="FeedUtil Example"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".WebViewActivity"
            android:exported="false" />
    </application>

</manifest>
